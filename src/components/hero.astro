---
interface Props {
  label: string;
  name: string;
  role: string;
  bio: string;
  facts: { label: string; value: string }[];
  links: { text: string; href: string }[];
  footer: string;
  langSwitch: { text: string; href: string };
}

const { label, name, role, bio, facts, links, footer, langSwitch } = Astro.props;
---

<div class="shell">
  <div class="grid-overlay" aria-hidden="true"></div>
  <div class="inner">
    <p class="label">{label}</p>
    <h1 class="name">{name}</h1>
    <p class="role" set:html={role}></p>

    <p class="bio" set:html={bio}></p>

    <div class="facts">
      {facts.map(f => (
        <div class="fact">
          <span class="fact-label">{f.label}</span>
          <span>{f.value}</span>
        </div>
      ))}
    </div>

    <div class="links">
      {links.map(l => (
        <a href={l.href} target={l.href.startsWith("mailto") ? "_self" : "_blank"}>{l.text}</a>
      ))}
    </div>
  </div>
  <p class="footer">{footer}</p>
  <a class="lang-switch" href={langSwitch.href}>{langSwitch.text}</a>
</div>

<style>
  .shell {
    position: relative;
    height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--border) 1px, transparent 1px),
      linear-gradient(90deg, var(--border) 1px, transparent 1px);
    background-size: 48px 48px;
    opacity: 0.35;
    pointer-events: none;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
  }

  .inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 580px;
    width: 100%;
    padding: 0 24px;
  }

  .label {
    color: var(--accent-dim);
    font-size: 12px;
    letter-spacing: 0.1em;
  }

  .name {
    font-family: var(--serif);
    font-size: clamp(48px, 6vw, 80px);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--text);
  }

  .role {
    color: var(--muted);
    font-size: 13px;
    letter-spacing: 0.06em;
  }

  .bio {
    color: var(--text);
    opacity: 0.75;
    font-size: 13px;
    line-height: 1.85;
  }

  .facts {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 20px 0;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
  }

  .fact {
    display: flex;
    justify-content: space-between;
    font-size: 13px;
  }

  .fact-label {
    color: var(--accent-dim);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .links {
    display: flex;
    gap: 24px;
    justify-content: center;
  }

  .links a {
    color: var(--muted);
    font-size: 13px;
    letter-spacing: 0.08em;
    transition: color 0.2s;
  }

  .links a:hover {
    color: var(--accent);
    text-decoration: none;
  }

  .footer {
    position: absolute;
    bottom: 28px;
    font-size: 12px;
    color: var(--muted);
  }

  .lang-switch {
    display: flex;
    gap: 24px;
    justify-content: center;
    font-size: 18px;
    letter-spacing: 0.08em;
    color: var(--muted);
    transition: color 0.2s;
  }

  .lang-switch:hover {
    color: var(--accent);
    text-decoration: none;
  }
</style>
